# Security headers (defense in depth)
Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "same-origin"
Header always set X-Frame-Options "DENY"
Header set Content-Security-Policy "default-src 'self'; object-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"

# Block dotfiles (.gitignore, .env, .htpasswd, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block dot-prefixed paths in subdirectories too (.git/config, .env/anything)
# Uitzondering voor .well-known/ (Let's Encrypt, security.txt)
RewriteEngine On
RewriteRule "^\.well-known/" - [L]
RewriteRule "(^|/)\." - [F]
